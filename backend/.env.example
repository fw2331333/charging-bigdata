# =============================================================================
# 复制本文件为 backend/.env 后按需修改（.env 勿提交 Git）
# Web 演示模式：MySQL + 本文件配置即可跑通图表页与邮箱登录注册
# =============================================================================

# ---------- MySQL（图表数据来源 + 用户表，必填）----------
# 首次部署需导入 sql/auth_schema.sql、sql/migrations/*.sql
# 邮箱注册功能额外需要：sql/migrations/004_email_verification.sql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=charging_bigdata

# ---------- 跨域（前端 dev 默认端口，多个用英文逗号分隔）----------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- JWT 双 Token（生产环境务必修改 JWT_SECRET）----------
# Access Token：短期，用于 API 鉴权（Authorization: Bearer ...）
# Refresh Token：长期，用于 /auth/refresh 轮换续期
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ---------- 邮箱注册 / 忘记密码（参考 offer-catch 流程）----------
#
# 【流程】
#   注册(邮箱+昵称) → 邮件链接 → /set-password 设密码 → 登录
#   忘记密码 → 邮件链接 → 设新密码
#   未验证登录 → 403，可点「重发验证邮件」
#
# 【数据库】
#   mysql -uroot -p charging_bigdata < sql/migrations/004_email_verification.sql
#
# APP_PUBLIC_URL
#   前端可访问地址，写入邮件中的「设置密码」链接
#   本地开发：http://127.0.0.1:5173
#   生产部署：改为实际域名，如 https://your-domain.com
APP_PUBLIC_URL=http://127.0.0.1:5173
#
# EMAIL_VERIFY_EXPIRE_HOURS
#   邮件令牌有效期（小时），超时需重新注册或忘记密码
EMAIL_VERIFY_EXPIRE_HOURS=24
#
# PROFILE_OTP_EXPIRE_MINUTES
#   个人资料「修改密码」邮箱验证码有效期（分钟）
PROFILE_OTP_EXPIRE_MINUTES=10

# ---------- SMTP 发信（QQ 邮箱示例）----------
#
# QQ 邮箱获取授权码：邮箱设置 → 账户 → POP3/SMTP → 开启 → 生成授权码
# SMTP_PASSWORD 填授权码，不是 QQ 登录密码
#
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587              # 587+STARTTLS；465 则自动走 SSL
# SMTP_USER=123456789@qq.com
# SMTP_PASSWORD=abcdefghijklmnop
# SMTP_FROM=充电大数据平台 <123456789@qq.com>
# SMTP_USE_TLS=true          # 端口 587 时保持 true

# ---------- 智能助手（DeepSeek / OpenAI 兼容 API + RAG，可选）----------
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_TIMEOUT_SECONDS=90
# RAG_TOP_K=4
# RAG_USE_VECTOR=true
# RAG_CHROMA_DIR=chroma_db
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# RAG_INSECURE_SSL=false     # Windows 下载 BGE 证书失败时可设 true

# ---------- 机器学习模型目录（预测页需要）----------
# 相对 backend/ 目录；默认指向 analytics/output
# 若使用 release/web-demo-models.zip 解压到 analytics/output/models/
ANALYTICS_OUTPUT_DIR=../analytics/output

# ---------- HDFS（Web 演示可忽略，仅直连 HDFS 读 CSV 时需要）----------
HDFS_NN_HOST=http://localhost:9870
HDFS_USER=hadoop

# ---------- ETL 流水线回调（可选）----------
# PIPELINE_SECRET=charging-pipeline-dev
# BACKEND_URL=http://127.0.0.1:8000
