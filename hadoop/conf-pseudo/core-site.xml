<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  单机伪分布式 core-site.xml
  - fs.defaultFS 使用 hadoop-master，与 install-pseudo-distributed.sh 中 /etc/hosts 一致
  - 扩展三节点时：复制 conf-cluster/ 全套配置，见 hadoop/cluster/deploy-cluster-config.sh
-->
<configuration>
  <property>
    <name>fs.defaultFS</name>
    <value>hdfs://hadoop-master:9000</value>
  </property>
  <property>
    <name>hadoop.tmp.dir</name>
    <value>file:/data/hadoop/tmp</value>
  </property>
</configuration>
