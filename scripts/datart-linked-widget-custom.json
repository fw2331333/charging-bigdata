      "options": { "modalSize": "middle" },
      "rows": [{ "label": "drillThrough.title", "key": "setting", "comType": "interaction.drillThrough" }]
    },
    {
      "label": "crossFiltering.title",
      "key": "crossFiltering",
      "comType": "checkboxModal",
      "default": false,
      "options": { "modalSize": "middle" },
      "rows": [{ "label": "crossFiltering.title", "key": "setting", "comType": "interaction.crossFiltering" }]
    },
    {
      "label": "viewDetail.title",
      "key": "viewDetail",
      "comType": "checkboxModal",
      "default": false,
      "options": { "modalSize": "middle" },
      "rows": [{ "label": "viewDetail.title", "key": "setting", "comType": "interaction.viewDetail" }]
    }
