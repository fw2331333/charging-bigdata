# 复制本文件为 backend/.env 后按需修改
# Web 演示模式（无需 Hadoop）：只需 MySQL + 下方配置即可跑通图表页

# ---------- MySQL（图表数据来源，必填）----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=charging_bigdata

# ---------- 跨域（前端 dev 默认端口）----------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- 机器学习模型目录（预测页需要）----------
# 相对 backend/ 目录；默认指向 analytics/output
# 若使用 release/web-demo-models.zip 解压到 analytics/output/models/
ANALYTICS_OUTPUT_DIR=../analytics/output

# ---------- HDFS（Web 演示可忽略，仅直连 HDFS 读 CSV 时需要）----------
HDFS_NN_HOST=http://localhost:9870
HDFS_USER=hadoop
