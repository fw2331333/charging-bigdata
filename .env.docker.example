# =============================================================================
# 阿里云 / Docker 部署环境文件
# 用法：cp .env.docker.example .env.docker  →  填真实值  →  勿提交 Git
#
# 与本机 backend/.env 的对应关系：
#   backend/.env          →  本机 npm run dev + uvicorn（端口 5173/8000）
#   .env.docker（本文件） →  docker compose 读入并注入 backend 容器
# =============================================================================

# ---------- Docker 栈 ----------
MYSQL_ROOT_PASSWORD=charging123
WEB_PORT=8080

# ---------- 公网访问（必改：换成阿里云 ECS 公网 IP）----------
# 邮件里的「设置密码」链接、CORS 都依赖 APP_PUBLIC_URL / CORS_ORIGINS
PUBLIC_HOST=http://115.29.194.137:8080
CORS_ORIGINS=http://115.29.194.137:8080
APP_PUBLIC_URL=http://115.29.194.137:8080

# ---------- JWT（生产必改，勿用默认值）----------
JWT_SECRET=change-me-to-random-long-string-at-least-32-chars
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ---------- 邮箱 SMTP（从 backend/.env 原样搬过来，改 APP_PUBLIC_URL 即可）----------
EMAIL_VERIFY_EXPIRE_HOURS=24
PROFILE_OTP_EXPIRE_MINUTES=10
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=你的QQ邮箱@qq.com
SMTP_PASSWORD=QQ邮箱SMTP授权码
SMTP_FROM=充电大数据平台 <你的QQ邮箱@qq.com>
SMTP_USE_TLS=true

# ---------- 智能助手 DeepSeek + RAG（从 backend/.env 搬 LLM_* / RAG_*）----------
LLM_API_KEY=sk-你的DeepSeek密钥
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=90
RAG_TOP_K=4
RAG_USE_VECTOR=true
RAG_CHROMA_DIR=chroma_db
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# BGE 向量缓存（先运行 python scripts/download_bge_cache.py，再挂载到容器）
FASTEMBED_CACHE_PATH=/app/fastembed_cache
HF_ENDPOINT=https://hf-mirror.com
RAG_INSECURE_SSL=true

# ---------- Datart BI（可选，叠加 docker-compose.datart.yml）----------
DATART_PORT=8088
VITE_DATART_BASE_URL=http://115.29.194.137:8088
VITE_DATART_DASHBOARD_URL=

# ---------- 以下本机 backend/.env 有、Docker 一般不用改 ----------
# MYSQL_HOST / PORT  → compose 里固定为 mysql:3306
# HDFS_*             → Web 演示不需要
# ANALYTICS_OUTPUT_DIR → compose 里已挂载 models 目录
