# =============================================================================
# 复制为 pipeline.env 后修改（勿提交含密码的 pipeline.env）
# 虚拟机共享目录请用 LF 换行；若报 $'\r' 错误，脚本会自动修复
# =============================================================================

HADOOP_HOME=/usr/local/hadoop
JAVA_HOME=/usr/local/jdk1.8.0_162
SPARK_HOME=/usr/local/spark

HDFS_INPUT=/Car/dsv13r1.csv
HDFS_OUTPUT_BASE=/Car/output
HDFS_ADS_DSV=/Car/dsv13r2.csv
HDFS_ADS_NVV=/Car/nvv2t.csv

DATASET_LOCAL_DIR=/media/sf_cs-/dataset

MYSQL_HOST=10.0.2.2
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=请修改
MYSQL_DATABASE=charging_bigdata

SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=1g
MYSQL_JDBC_JAR=/media/sf_cs-/charging-bigdata/spark/jars/mysql-connector-j-8.0.33.jar

SKIP_MR=0
SKIP_ETL=0
SKIP_BUILD=0
SKIP_ADS=0
